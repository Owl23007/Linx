#!/bin/bash
# MODE: STAGED_ONLY

# pre-commit hook to run lint check on staged files only
echo "Running ESLint check on staged files..."

# Change to front directory
cd front

# Get list of staged files in front directory
staged_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(vue|js|ts|jsx|tsx)$' | grep '^front/' | sed 's|^front/||')

if [ -z "$staged_files" ]; then
    echo "No front-end files to lint. Skipping ESLint check."
    exit 0
fi

echo "Checking files: $staged_files"

# Run lint check on staged files only
npm run lint -- $staged_files

# Check the exit code
if [ $? -eq 0 ]; then
    echo "✅ ESLint check passed. Proceeding with commit..."
    exit 0
else
    echo "❌ ESLint check failed. Please fix the linting errors before committing."
    echo "You can run 'npm run lint:fix' to automatically fix some issues."
    exit 1
fi
