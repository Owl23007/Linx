{
  "name": "linx",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "homepage": "./",
  "description": "Linx - A modern communication application",
  "author": "Linx Team",
  "license": "MIT",
  "keywords": [
    "electron",
    "vue",
    "communication",
    "chat"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Owl23007/Let-s-Talk.git"
  },
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "vite --host",
    "electron": "cross-env NODE_ENV=development electron .",
    "electron:prod": "cross-env NODE_ENV=production electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "start": "npm run electron:dev",
    "build": "vue-tsc -b && vite build",
    "build:electron": "npm run build && cross-env NODE_ENV=production electron-builder",
    "build:electron:win": "npm run build && cross-env NODE_ENV=production electron-builder --win",
    "build:electron:mac": "npm run build && cross-env NODE_ENV=production electron-builder --mac",
    "build:electron:linux": "npm run build && cross-env NODE_ENV=production electron-builder --linux",
    "preview": "vite preview",
    "clean": "rimraf dist release",
    "clean:all": "rimraf dist release node_modules && npm install",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx",
    "lint:fix": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "lint:check": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --max-warnings 0",
    "format": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "type-check": "vue-tsc --noEmit",
    "rebuild": "electron-rebuild"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@stomp/stompjs": "^7.2.0",
    "axios": "^1.11.0",
    "better-sqlite3": "^12.2.0",
    "better-sqlite3-multiple-ciphers": "^12.2.0",
    "crypto-js": "^4.2.0",
    "element-plus": "^2.10.7",
    "keytar": "^7.9.0",
    "pinia": "^3.0.3",
    "sockjs-client": "^1.6.1",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.2",
    "@eslint/js": "^9.34.0",
    "@stylistic/eslint-plugin": "^5.2.3",
    "@tailwindcss/vite": "^4.1.12",
    "@types/sockjs-client": "^1.5.4",
    "@typescript-eslint/eslint-plugin": "^8.40.0",
    "@typescript-eslint/parser": "^8.40.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.7.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^38.0.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.34.0",
    "eslint-plugin-vue": "^10.4.0",
    "globals": "^16.3.0",
    "less": "^4.4.0",
    "rimraf": "^6.0.1",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.1.2",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.0.5",
    "wait-on": "^8.0.4"
  },
  "build": {
    "appId": "top.contins.linx",
    "productName": "Linx",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/database",
        "to": "database"
      }
    ],
    "npmRebuild": true,
    "buildDependenciesFromSource": true,
    "nodeGypRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
