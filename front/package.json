{
  "name": "linx",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "homepage": "./",
  "description": "Linx - A modern P2P application",
  "author": "Linx Team",
  "license": "MIT",
  "keywords": [
    "electron",
    "vue",
    "p2p"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Owl23007/Linx.git"
  },
  "scripts": {
    "postinstall": "electron-builder install-app-deps && npm run download:easytier",
    "download:easytier": "node scripts/download-easytier.js",
    "dev": "vp dev --host",
    "electron": "cross-env NODE_ENV=development electron .",
    "electron:prod": "cross-env NODE_ENV=production electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "start": "npm run electron:dev",
    "build:web": "vue-tsc -b && vp build",
    "build": "npm run build:web && cross-env NODE_ENV=production electron-builder",
    "build:win": "npm run build:web && cross-env NODE_ENV=production electron-builder --win",
    "build:mac": "npm run build:web && cross-env NODE_ENV=production electron-builder --mac",
    "build:linux": "npm run build:web && cross-env NODE_ENV=production electron-builder --linux",
    "preview": "vp preview",
    "check": "vp check && vp exec vue-tsc --noEmit",
    "clean": "rimraf dist release",
    "clean:all": "rimraf dist release node_modules && vp install",
    "lint": "vp lint .",
    "lint:fix": "vp lint . --fix",
    "lint:check": "vp lint . --max-warnings 0",
    "format": "vp fmt . --write",
    "type-check": "vue-tsc --noEmit",
    "rebuild": "electron-rebuild"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@stomp/stompjs": "^7.3.0",
    "axios": "^1.14.0",
    "better-sqlite3-multiple-ciphers": "^12.8.0",
    "element-plus": "^2.13.6",
    "keytar": "^7.9.0",
    "pinia": "^3.0.4",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "rimraf": "^6.1.3",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "catalog:",
    "vue-tsc": "^3.2.7",
    "wait-on": "^9.0.4",
    "vite-plus": "catalog:"
  },
  "build": {
    "appId": "top.contins.linx",
    "productName": "Linx",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/database",
        "to": "database"
      },
      {
        "from": "electron/bin",
        "to": "bin"
      }
    ],
    "npmRebuild": true,
    "buildDependenciesFromSource": false,
    "nodeGypRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  },
  "pnpm": {
    "overrides": {
      "node-gyp": "12.2.0",
      "node-abi": "4.28.0"
    }
  },
  "packageManager": "pnpm@10.33.0"
}
