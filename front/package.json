{
  "name": "linx",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.js",
  "homepage": "./",
  "description": "Linx - A modern communication application",
  "author": "Linx Team",
  "license": "MIT",
  "keywords": [
    "electron",
    "vue",
    "communication",
    "chat"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Owl23007/Let-s-Talk.git"
  },
  "scripts": {
    "postinstall": "electron-builder install-app-deps && node scripts/download-easytier.js",
    "download:easytier": "node scripts/download-easytier.js",
    "dev": "vite --host",
    "electron": "cross-env NODE_ENV=development electron .",
    "electron:prod": "cross-env NODE_ENV=production electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "start": "npm run electron:dev",
    "build:web": "vue-tsc -b && vite build",
    "build": "npm run build:web && cross-env NODE_ENV=production electron-builder",
    "build:win": "npm run build:web && cross-env NODE_ENV=production electron-builder --win",
    "build:mac": "npm run build:web && cross-env NODE_ENV=production electron-builder --mac",
    "build:linux": "npm run build:web && cross-env NODE_ENV=production electron-builder --linux",
    "preview": "vite preview",
    "clean": "rimraf dist release",
    "clean:all": "rimraf dist release node_modules && npm install",
    "lint": "eslint . --ext .vue,.js,.ts,.jsx,.tsx",
    "lint:fix": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "lint:check": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --max-warnings 0",
    "format": "eslint . --ext .vue,.js,.ts,.jsx,.tsx --fix",
    "type-check": "vue-tsc --noEmit",
    "rebuild": "electron-rebuild"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@stomp/stompjs": "^7.3.0",
    "axios": "^1.13.2",
    "better-sqlite3": "^12.5.0",
    "better-sqlite3-multiple-ciphers": "^12.5.0",
    "crypto-js": "^4.2.0",
    "element-plus": "^2.13.0",
    "keytar": "^7.9.0",
    "pinia": "^3.0.4",
    "sockjs-client": "^1.6.1",
    "vue": "^3.5.25",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@eslint/js": "^9.39.2",
    "@stylistic/eslint-plugin": "^5.6.1",
    "@tailwindcss/vite": "^4.1.18",
    "@types/sockjs-client": "^1.5.4",
    "@typescript-eslint/eslint-plugin": "^8.51.0",
    "@typescript-eslint/parser": "^8.51.0",
    "@vitejs/plugin-vue": "^6.0.3",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^39.2.4",
    "electron-builder": "^26.0.12",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "^10.6.2",
    "globals": "^17.0.0",
    "less": "^4.5.1",
    "rimraf": "^6.1.2",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.51.0",
    "vite": "^7.3.0",
    "vue-eslint-parser": "^10.2.0",
    "vue-tsc": "^3.1.5",
    "wait-on": "^9.0.3"
  },
  "build": {
    "appId": "top.contins.linx",
    "productName": "Linx",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "public/database",
        "to": "database"
      },
      {
        "from": "electron/bin",
        "to": "bin"
      }
    ],
    "npmRebuild": true,
    "buildDependenciesFromSource": true,
    "nodeGypRebuild": false,
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    }
  }
}
